# Shodan API Configuration
SHODAN_API_KEY=your_shodan_api_key_here

# Output Configuration
OUTPUT_DIR=./output
LOG_LEVEL=INFO

# Scan Configuration
MAX_RESULTS_PER_QUERY=1000
ENABLE_HOST_ENRICHMENT=true
MAX_ENRICHMENTS=100

# Rate Limiting
RATE_LIMIT_DELAY=1
QUERY_COOLDOWN=2

# Report Configuration
GENERATE_CSV=true
GENERATE_JSON=true
GENERATE_CHARTS=true

# Web Interface Configuration
WEB_API_KEY=change-me-to-a-strong-random-secret
WEB_HOST=127.0.0.1
WEB_PORT=8000

# NVD (National Vulnerability Database) Configuration
# Optional: obtain a free API key at https://nvd.nist.gov/developers/request-an-api-key
# Without a key: rate limit is 5 requests/30s (slower initial fetch)
# With a key: rate limit is 50 requests/30s
NVD_API_KEY=
# Cache TTL in hours before re-fetching from NVD (default: 24)
NVD_CACHE_TTL_HOURS=24

# MaxMind GeoIP Configuration
# Download .mmdb files with: scripts/download_geoip_dbs.sh
GEOIP_DB_DIR=./geoip_dbs
MAXMIND_LICENSE_KEY=your_maxmind_license_key_here
