# Frontend env vars. NEXT_PUBLIC_* values are inlined into the JS bundle at
# build time and shipped to browsers — set them BEFORE `pnpm build`.

# Dev: absolute URL pointing at the local FastAPI backend.
# Prod (single-origin nginx, see docs/deploy-frontend.md): use a relative path
# like "/api/v1" so the browser issues same-origin requests.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Shared key sent as `X-API-Key`. MUST match the backend's WEB_API_KEY.
NEXT_PUBLIC_WEB_API_KEY=bitcoin-scanner-dev
