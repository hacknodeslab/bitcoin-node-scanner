{
  "name": "bitcoin-node-scanner-frontend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "echo \"no tests yet\" && exit 0",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "tokens:gen": "tsx scripts/generate-design-tokens.ts",
    "tokens:check": "tsx scripts/generate-design-tokens.ts --check"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwind-merge": "3.5.0"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.0",
    "@eslint/eslintrc": "3.3.5",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.4",
    "postcss": "8.5.10",
    "prettier": "3.8.3",
    "tailwindcss": "3.4.19",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "yaml": "2.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
